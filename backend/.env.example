# ---- Core ----
APP_NAME=Wallmark Realtors API
ENVIRONMENT=production
# Your deployed frontend URL (Vercel). Used for CORS + links.
FRONTEND_URL=https://your-frontend.vercel.app
# Public site URL (used in sitemap.xml / robots.txt). Usually same as FRONTEND_URL.
SITE_URL=https://your-frontend.vercel.app

# ---- Database ----
# SQLite (default, zero-setup, works on Render free tier — see DEPLOYMENT.md note).
DATABASE_URL=sqlite:///./wallmark.db
# To use a persistent Render disk, mount it (e.g. at /var/data) and use:
# DATABASE_URL=sqlite:////var/data/wallmark.db
# Or use a managed Postgres (Neon/Supabase/Render):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---- Security / JWT ----
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- First admin (auto-seeded on startup) ----
ADMIN_EMAIL=admin@wallmarkrealtors.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Wallmark Admin

# ---- CORS ----
# Comma-separated exact origins (add your Vercel production domain here).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-frontend.vercel.app
# Optional regex to also allow Vercel preview deployments:
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# ---- Cloudinary (image uploads) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Email (SMTP) ----
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=wallmarkrealtors@gmail.com
MAIL_FROM_NAME=Wallmark Realtors
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
MAIL_TO=wallmarkrealtors@gmail.com

# ---- Business contact ----
COMPANY_PHONE=+91 98208 90001
COMPANY_WHATSAPP=919820890001
COMPANY_EMAIL=wallmarkrealtors@gmail.com
